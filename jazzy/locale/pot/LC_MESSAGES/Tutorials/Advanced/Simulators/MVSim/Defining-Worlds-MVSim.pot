msgid "`MVSim documentation <https://mvsimulator.readthedocs.io/>`__"
msgstr ""

#: ../../../source/Tutorials/Advanced/Simulators/MVSim/Defining-Worlds-MVSim.rst:341
msgid "`MVSim GitHub repository <https://github.com/MRPT/mvsim>`__"
msgstr ""

#: ../../../source/Tutorials/Advanced/Simulators/MVSim/Defining-Worlds-MVSim.rst:342
msgid ""
"`MVSim paper (SoftwareX) <https://doi.org/10.1016/j.softx.2023.101443>`__"
msgstr ""
