msgid ""
"Please see the original pr for more detail and comment there if this causes "
"issues:"
msgstr ""

#: ../../../source/Releases/Release-Eloquent-Elusor.rst:254
msgid ""
"`https://github.com/ros2/rclcpp/pull/867 <https://github.com/ros2/rclcpp/"
"pull/867>`_"
msgstr ""

