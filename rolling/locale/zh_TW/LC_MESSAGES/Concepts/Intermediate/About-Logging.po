#: ../../../source/Concepts/Intermediate/About-Logging.rst:269
msgid "Example usage"
msgstr ""

#: ../../../source/Concepts/Intermediate/About-Logging.rst:275
#: ../../../source/Concepts/Intermediate/About-Logging.rst:287
msgid ""
"# Use spdlog for logging (default behavior)\n"
"export RCL_LOGGING_IMPLEMENTATION=rcl_logging_spdlog\n"
"ros2 run demo_nodes_cpp talker\n"
"\n"
"# Use no-op logging implementation that discards all log messages to the "
"logging backend\n"
"export RCL_LOGGING_IMPLEMENTATION=rcl_logging_noop\n"
"ros2 run demo_nodes_cpp talker"
msgstr ""

#: ../../../source/Concepts/Intermediate/About-Logging.rst:299
msgid ""
"# Use spdlog for logging (default behavior)\n"
"set RCL_LOGGING_IMPLEMENTATION=rcl_logging_spdlog\n"
"ros2 run demo_nodes_cpp talker\n"
"\n"
"# Use no-op logging implementation that discards all log messages to the "
"logging backend\n"
"set RCL_LOGGING_IMPLEMENTATION=rcl_logging_noop\n"
"ros2 run demo_nodes_cpp talker"
msgstr ""

